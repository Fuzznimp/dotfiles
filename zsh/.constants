# ─── System ──────────────────────────────────────────────

export WORKSPACE_PATH="$HOME/workspace"
export DOTFILES_PATH="$WORKSPACE_PATH/dotfiles"
export DOTFILES_ZSH_PATH="$WORKSPACE_PATH/dotfiles/zsh"
export DOTFILES_NVIM_PATH="$DOTFILES_PATH/nvim"
export DOTFILES_APP_PATH="$DOTFILES_PATH/Library/Application\ Support"
export DOTFILES_CONFIG_PATH="$DOTFILES_PATH/.config"
export DOTFILES_TMUX_PATH="$DOTFILES_CONFIG_PATH/tmux"

# ─── Work ────────────────────────────────────────────────

export FEWLINES_PATH="$HOME/workspace/fewlines"
export SENCROP_PATH="$HOME/workspace/sencrop"

# ─── Misc ────────────────────────────────────────────────

# Use nvim as $EDITOR.
export VISUAL=nvim

## https://github.com/achristmascarl/rainfrog
export RAINFROG_CONFIG=~/.config/rainfrog
export RAINFROG_FAVORITES=~/.config/rainfrog/favorites
